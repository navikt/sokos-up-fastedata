{
	"name": "sokos-up-fastedata",
	"version": "1.0.0",
	"description": "Arbeidsflate for Faste data i Utbetalingsportalen",
	"type": "module",
	"scripts": {
		"dev": "vite --mode mock",
		"dev:backend": "vite --mode backend",
		"build": "tsc && vite build",
		"playwright": "playwright test",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@grafana/faro-web-sdk": "2.8.2",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-css": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"axios": "1.18.1",
		"dayjs": "1.11.21",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-router": "7.17.0",
		"swr": "2.4.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@biomejs/biome": "2.5.2",
		"@navikt/aksel-stylelint": "7.40.0",
		"@playwright/test": "1.61.1",
		"@types/node": "26.1.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"husky": "9.1.7",
		"jsdom": "29.1.1",
		"lint-staged": "17.0.8",
		"msw": "2.14.6",
		"stylelint": "17.14.0",
		"stylelint-config-standard": "40.0.0",
		"typescript": "6.0.3",
		"vite": "8.1.3",
		"vite-plugin-css-injected-by-js": "5.0.1"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"stylelint": {
		"extends": [
			"stylelint-config-standard",
			"@navikt/aksel-stylelint/recommended"
		],
		"ignoreFiles": "dist/**/*"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.5.3",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
